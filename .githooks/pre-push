#!/usr/bin/env bash
set -euo pipefail

EMPTY_TREE="$(git hash-object -t tree /dev/null)"
DIST_DMG="dist/Whisper-Anywhere-unsigned.dmg"
WEB_DMG="website/downloads/Whisper-Anywhere-unsigned.dmg"

release_required=0
dist_dmg_changed=0
web_dmg_changed=0

is_zero_sha() {
  [[ "$1" =~ ^0+$ ]]
}

mark_changes() {
  local local_sha="$1"
  local remote_sha="$2"
  local changed

  if is_zero_sha "$remote_sha"; then
    changed="$(git diff --name-only "$EMPTY_TREE" "$local_sha")"
  else
    changed="$(git diff --name-only "$remote_sha" "$local_sha")"
  fi

  while IFS= read -r path; do
    [[ -z "$path" ]] && continue

    case "$path" in
      NativeWhisper/*|NativeWhisperTests/*|Package.swift)
        release_required=1
        ;;
    esac

    [[ "$path" == "$DIST_DMG" ]] && dist_dmg_changed=1
    [[ "$path" == "$WEB_DMG" ]] && web_dmg_changed=1
  done <<< "$changed"
}

while read -r local_ref local_sha remote_ref remote_sha; do
  # Branch deletion pushes have local SHA of all zeros.
  if is_zero_sha "$local_sha"; then
    continue
  fi

  mark_changes "$local_sha" "$remote_sha"
done || true

if [[ "$release_required" -eq 0 ]]; then
  exit 0
fi

if [[ "$dist_dmg_changed" -ne 1 || "$web_dmg_changed" -ne 1 ]]; then
  cat >&2 <<MSG
Push blocked: app/runtime changes detected, but full release artifacts are not both updated.
Required files:
  - $DIST_DMG
  - $WEB_DMG
Run: ./scripts/full_release.sh
MSG
  exit 1
fi

# Ensure the committed DMG bytes are identical at HEAD.
dist_blob="$(git rev-parse "HEAD:$DIST_DMG" 2>/dev/null || true)"
web_blob="$(git rev-parse "HEAD:$WEB_DMG" 2>/dev/null || true)"

if [[ -z "$dist_blob" || -z "$web_blob" ]]; then
  cat >&2 <<MSG
Push blocked: required DMG artifacts are missing at HEAD.
Required files:
  - $DIST_DMG
  - $WEB_DMG
MSG
  exit 1
fi

if [[ "$dist_blob" != "$web_blob" ]]; then
  cat >&2 <<MSG
Push blocked: DMG artifacts differ.
Expected byte-identical files:
  - $DIST_DMG
  - $WEB_DMG
Run: ./scripts/full_release.sh
MSG
  exit 1
fi

exit 0
